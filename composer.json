{
    "name": "binarylogic/tor-exit-nodes",
    "description": "Download the Tor exit nodes list and check if a given IP address is a Tor exit node.",
    "type": "library",
    "authors": [
        {
            "name": "Binary Logic",
            "email": "contact@binarylogic.ro",
            "homepage": "https://binarylogic.ro/"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.15",
        "symfony/filesystem": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Binarylogic\\TorExitNodes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "format": "php-cs-fixer fix",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    }
}
